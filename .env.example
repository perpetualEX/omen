# Copy this file to .env and fill in the values. Never commit .env.

# --- Rollup (filled in after Phase 1) ---
OMEN_CHAIN_ID=omen-testnet-1
OMEN_EVM_CHAIN_ID=
OMEN_RPC_URL=https://json-rpc.omen-testnet-1.initia.tech
OMEN_REST_URL=https://rest.omen-testnet-1.initia.tech
OMEN_EXPLORER_URL=https://scan.initia.xyz/omen-testnet-1

# --- Deployer (has INIT to pay gas + can create contracts) ---
DEPLOYER_PRIVATE_KEY=0x

# --- AI Agent (a separate key from deployer; holds seed collateral) ---
AGENT_PRIVATE_KEY=0x
AGENT_ADDRESS=0x

# --- Contracts (filled in after Phase 2) ---
TREASURY_ADDRESS=0x
MARKET_FACTORY_ADDRESS=0x
COLLATERAL_TOKEN_ADDRESS=0x

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-

# --- Optional: Ethereum mainnet RPC so the agent can watch on-chain activity ---
ETH_MAINNET_RPC_URL=https://eth.llamarpc.com
